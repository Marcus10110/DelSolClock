# Copy to .env (gitignored) and fill in your Mapbox public token (pk.*).
# A default public token with no special scopes is sufficient.

# Used by the Node tools (tools/capture-route.mjs, tools/send-route.ts).
# Leave URL restrictions OFF for these (they run in Node, not a browser).
MAPBOX_TOKEN=

# Used by the browser app (Vite exposes only VITE_-prefixed vars). Same value as
# MAPBOX_TOKEN is fine for dev. For the public site, use a URL-restricted token.
VITE_MAPBOX_TOKEN=
